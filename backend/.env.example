# ============================================================
# ENVIRONMENT CONFIG — copy this file to .env and fill in values
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# If you're using a local Postgres install:
DATABASE_URL=postgresql://neondb_owner:npg_qzWBLZigf79U@ep-late-block-aorw6c13-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# If you're using a hosted Postgres (Neon, Supabase, Railway etc.)
# just paste the connection string they give you here instead.

# --- Auth / JWT ---
# Use a long random string in production. For dev, anything works.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173
